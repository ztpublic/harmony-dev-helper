{
  "name": "@harmony/vscode-extension",
  "version": "0.1.0",
  "private": true,
  "displayName": "Harmony Dev Helper",
  "engines": {
    "vscode": "^1.95.0"
  },
  "main": "./out/extension.js",
  "activationEvents": ["onCommand:harmony.openWebview"],
  "contributes": {
    "commands": [
      {
        "command": "harmony.openWebview",
        "title": "Harmony: Open Shared Webview"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@harmony/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.8.2"
  }
}
